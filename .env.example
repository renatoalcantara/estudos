# Analytics (opcional). Carregam APENAS em build de produção.
# Para testar localmente: copie para .env.local e rode `npm run build && npm run preview`.
# Em deploy (ex.: Vercel): defina estas variáveis nas Environment Variables do projeto.

# Google Analytics 4 — Measurement ID (Admin > Fluxos de dados)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Microsoft Clarity — Project ID (Settings > Overview, ou da tag de instalação)
VITE_CLARITY_PROJECT_ID=xxxxxxxxxx
