---
interface Props {
  caption: string;
}

const { caption } = Astro.props;
---

<figure class="mx-auto max-w-6xl px-6">
  <div
    class="relative aspect-[16/9] w-full overflow-hidden rounded-sm bg-ink"
  >
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,_rgba(246,241,231,0.15),_transparent_55%),radial-gradient(circle_at_75%_80%,_rgba(168,51,31,0.45),_transparent_60%)]"
    >
    </div>
    <div
      class="absolute inset-0 bg-[linear-gradient(110deg,_rgba(26,23,20,0.85)_0%,_rgba(26,23,20,0.4)_45%,_rgba(168,51,31,0.55)_100%)]"
    >
    </div>
    <div
      class="absolute inset-0 mix-blend-overlay opacity-40"
      style="background-image: repeating-linear-gradient(90deg, rgba(255,255,255,0.06) 0 1px, transparent 1px 4px);"
    >
    </div>
    <div class="absolute inset-x-0 bottom-0 p-6 md:p-10">
      <p
        class="font-sans text-[10px] uppercase tracking-[0.4em] text-paper/70"
      >
        Da série
      </p>
      <p class="mt-2 font-serif text-2xl italic text-paper md:text-3xl">
        Quartos vazios
      </p>
    </div>
  </div>
  <figcaption
    class="mt-3 px-1 font-sans text-xs italic text-ink-soft"
  >
    {caption}
  </figcaption>
</figure>
