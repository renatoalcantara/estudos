---
interface Props {
  number: string;
  label: string;
}

const { number, label } = Astro.props;
---

<header class="mt-20 mb-8">
  <div class="flex items-baseline gap-4 font-sans text-xs uppercase tracking-[0.32em] text-accent">
    <span>{number}</span>
    <span class="h-px flex-1 bg-rule"></span>
  </div>
  <h2
    class="mt-5 font-serif text-3xl font-medium leading-[1.1] tracking-tight md:text-4xl"
  >
    {label}
  </h2>
</header>
